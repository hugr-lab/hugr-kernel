{
  "name": "@hugr-lab/graphql-ide",
  "version": "0.1.0",
  "description": "GraphQL IDE experience for Hugr Kernel in JupyterLab — completion, diagnostics, hover, formatting, and schema explorer",
  "license": "MIT",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "style": "style/index.css",
  "keywords": [
    "jupyter",
    "jupyterlab",
    "jupyterlab-extension",
    "graphql",
    "hugr"
  ],
  "files": [
    "lib/**/*.{d.ts,js,js.map,json}",
    "style/**/*.{css,js}",
    "src/**/*.{ts,tsx}"
  ],
  "scripts": {
    "build": "jlpm build:lib && jlpm build:labextension:dev",
    "build:prod": "jlpm build:lib:prod && jlpm build:labextension",
    "build:lib": "tsc --sourceMap",
    "build:lib:prod": "tsc",
    "build:labextension": "jupyter labextension build .",
    "build:labextension:dev": "jupyter labextension build --development True .",
    "clean": "rimraf lib hugr_graphql_ide/labextension",
    "watch": "run-p watch:src watch:labextension",
    "watch:src": "tsc -w --sourceMap",
    "watch:labextension": "jupyter labextension watch ."
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.16.0",
    "@codemirror/language": "^6.10.0",
    "@codemirror/state": "^6.4.0",
    "@codemirror/view": "^6.26.0",
    "@jupyterlab/application": "^4.0.0",
    "@jupyterlab/apputils": "^4.0.0",
    "@jupyterlab/codemirror": "^4.0.0",
    "@jupyterlab/notebook": "^4.0.0",
    "@jupyterlab/rendermime-interfaces": "^3.8.0",
    "@jupyterlab/services": "^7.0.0",
    "@jupyterlab/ui-components": "^4.0.0",
    "@lezer/highlight": "^1.2.0",
    "@lumino/widgets": "^2.1.0",
    "prettier": "^3.2.0"
  },
  "devDependencies": {
    "@jupyterlab/builder": "^4.0.0",
    "npm-run-all2": "^7.0.1",
    "rimraf": "^5.0.1",
    "typescript": "~5.8.0"
  },
  "sideEffects": [
    "style/*.css",
    "style/index.js"
  ],
  "styleModule": "style/index.js",
  "jupyterlab": {
    "extension": "lib/plugin.js",
    "schemaDir": "schema",
    "outputDir": "hugr_graphql_ide/labextension",
    "sharedPackages": {
      "@jupyterlab/codemirror": {
        "bundled": false,
        "singleton": true
      },
      "@jupyterlab/services": {
        "bundled": false,
        "singleton": true
      }
    }
  }
}
